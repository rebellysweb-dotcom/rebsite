# ============================================================
# REBELLYS — Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# Supabase — get from: supabase.com → project → settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend — get from: resend.com → API Keys
# Use a sending address from your verified domain, e.g. orders@rebellys.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=orders@rebellys.com
RESEND_FROM_NAME=Rebelly's Flower Shop

# Site URL — used for auth callbacks and canonical tags
NEXT_PUBLIC_SITE_URL=https://rebellys.com

# Shop contact info (also editable from admin panel via DB settings)
NEXT_PUBLIC_SHOP_WHATSAPP=96176585028
NEXT_PUBLIC_SHOP_PHONE=+96176585028
NEXT_PUBLIC_SHOP_ADDRESS=Saydeh Street, Zalka, Lebanon

# Google OAuth (set up in Supabase dashboard → Auth → Providers → Google)
# You don't need to add these here — Supabase handles it via dashboard
# But if using directly:
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin notification email (receives new order alerts)
ADMIN_EMAIL=your-admin@email.com

# PostHog analytics — get from: posthog.com → Project Settings → Project API Key
# Host is https://us.i.posthog.com (US cloud) or https://eu.i.posthog.com (EU cloud)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

